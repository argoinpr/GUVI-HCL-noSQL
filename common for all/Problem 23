// Find products needing restock (Stock < Reorder Level)
db.inventory.find({
  $expr: { $lt: ["$quantity_in_stock", "$reorder_level"] }
});

// Add 100 to stock for ToolWorks products
db.inventory.updateMany(
  { supplier_name: "ToolWorks" },
  { $inc: { quantity_in_stock: 100 } }
);

// Delete dead stock (0 quantity, not restocked since before 2022)
db.inventory.deleteMany({
  quantity_in_stock: 0,
  last_restock_date: { $lt: ISODate("2022-01-01T00:00:00Z") }
});

// Create index to optimize queries by category and stock
db.inventory.createIndex({ category: 1, quantity_in_stock: -1 });
