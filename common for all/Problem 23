  { product_id: "PR002", product_name: "Safety Goggles", category: "Safety", quantity_in_stock: 50, reorder_level: 30, supplier_name: "SafeGuard", last_restock_date: ISODate("2026-04-15T00:00:00Z"), storage_location: "Aisle 4" },
  { product_id: "PR003", product_name: "Hammer", category: "Tools", quantity_in_stock: 5, reorder_level: 15, supplier_name: "ToolWorks", last_restock_date: ISODate("2024-11-20T00:00:00Z"), storage_location: "Aisle 1" },
  { product_id: "PR004", product_name: "Steel Bolts", category: "Hardware", quantity_in_stock: 0, reorder_level: 100, supplier_name: "Boltify", last_restock_date: ISODate("2021-06-01T00:00:00Z"), storage_location: "Aisle 9" },
